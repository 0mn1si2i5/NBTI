{
  "name": "nbti",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "node scripts/clean-generated.mjs",
    "assets:build": "node scripts/optimize-assets.mjs",
    "predev": "npm run assets:build",
    "dev": "vite --host 127.0.0.1",
    "prebuild": "npm run assets:build",
    "build": "vite build",
    "validate:build-budget": "node scripts/validate-build-budget.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "audit:copy": "node scripts/audit-copy.mjs",
    "docs:sync": "tsx scripts/sync-docs.ts --write",
    "validate:docs": "tsx scripts/sync-docs.ts --check",
    "analyze:matching": "tsx scripts/analyze-matching.ts --ci",
    "validate:privacy": "node scripts/validate-privacy.mjs",
    "prevalidate:data": "npm run assets:build",
    "validate:data": "tsx scripts/validate-data.ts"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "sharp": "^0.35.3",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
