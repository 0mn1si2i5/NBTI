          "tui_jin": 1
        }
      },
      {
        "id": "c",
        "label": "C",
        "text": "提前订好两处想看的地方，按时间出发。",
        "delta": {
          "qi_zheng": 2,
          "tui_jin": 1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "只在住处附近随便拐，累了就回来。",
        "delta": {
          "qi_zheng": -1,
          "tui_jin": -1
        }
      }
    ]
  },
  {
