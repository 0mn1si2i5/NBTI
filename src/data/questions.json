        }
      },
      {
        "id": "c",
        "label": "C",
        "text": "直接说这次不能帮，也把自己的边界讲清。",
        "delta": {
          "rou_gang": 2,
          "po_li": 1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "用玩笑把话岔开，让对方自己听出不方便。",
        "delta": {
          "rou_gang": -1,
          "po_li": -1
        }
      }
    ]
  },
  {
