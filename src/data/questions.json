      "primaryAxis": "kuang_zhi",
      "secondaryAxis": "rou_gang",
      "distinguishes": [
        "陶渊明",
        "葛洪",
        "桓温",
        "谢灵运"
      ]
    },
    "options": [
      {
        "id": "a",
        "label": "A",
        "text": "跳到结尾看一眼，再决定要不要补完。",
        "delta": {
          "kuang_zhi": 1,
          "rou_gang": -1
        }
      },
      {
        "id": "b",
        "label": "B",
        "text": "承认它已经失去吸引力，现在就合上。",
        "delta": {
          "kuang_zhi": -2,
          "rou_gang": 1
        }
      },
      {
        "id": "c",
        "label": "C",
        "text": "既然读到这里，还是把最后一段走完。",
        "delta": {
          "kuang_zhi": 2,
          "rou_gang": 1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "夹好书签放回去，也许以后会想起来。",
        "delta": {
          "kuang_zhi": -1,
          "rou_gang": -1
        }
      }
    ]
  },
  {
    "id": "q11",
    "type": "scenario",
    "text": "你独自在一座陌生城市多出半天空闲，没有必须完成的安排。",
