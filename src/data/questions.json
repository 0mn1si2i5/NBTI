[
  {
    "id": "q01",
    "type": "scenario",
    "text": "四个人约一次短途旅行。聊了三天，时间还没定下来。",
    "design": {
      "primaryAxis": "tui_jin",
      "secondaryAxis": "po_li",
      "distinguishes": [
        "王导",
        "刘裕",
        "陶渊明",
        "山涛"
      ]
    },
    "options": [
      {
        "id": "a",
        "label": "A",
        "text": "把大家空闲的日期整理成两档，发群里等人选。",
        "delta": {
          "tui_jin": -2,
          "po_li": 1
        }
      },
      {
        "id": "b",
        "label": "B",
        "text": "先放着。真想去的人，过两天还会再提。",
        "delta": {
          "tui_jin": -1,
          "po_li": -1
        }
      },
      {
        "id": "c",
        "label": "C",
        "text": "提一个具体时间，不行的人再往后改。",
        "delta": {
          "tui_jin": 1,
          "po_li": 1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "先订一个可以退的住处，决定去的人自然会跟上。",
        "delta": {
          "tui_jin": 2,
          "po_li": -1
        }
      }
    ]
  },
  {
    "id": "q02",
    "type": "scenario",
    "text": "家里有条沿用多年的规矩，如今已经没人说得清它有什么用。",
    "design": {
      "primaryAxis": "po_li",
      "secondaryAxis": "xu_shi",
      "distinguishes": [
        "王猛",
        "王导",
        "元宏",
        "嵇康"
      ]
    },
    "options": [
      {
        "id": "a",
        "label": "A",
        "text": "先问清谁还在依赖它；没人需要，就正式取消。",
        "delta": {
          "po_li": -2,
          "xu_shi": 1
        }
      },
      {
        "id": "b",
        "label": "B",
        "text": "表面照旧，私下各过各的，别为这件事开会。",
        "delta": {
          "po_li": -1,
          "xu_shi": -1
        }
      },
      {
        "id": "c",
        "label": "C",
        "text": "把例外写清楚，其余部分仍按原来的办。",
        "delta": {
          "po_li": 1,
          "xu_shi": 1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "给它换一个大家还能接受的说法，先把场面维持住。",
        "delta": {
          "po_li": 2,
          "xu_shi": -1
        }
      }
    ]
  },
  {
    "id": "q03",
    "type": "scenario",
    "text": "你要在两个都不算坏的选择里做决定，但手里的信息永远不会齐。",
    "design": {
      "primaryAxis": "xu_shi",
      "secondaryAxis": "kuang_zhi",
      "distinguishes": [
        "王弼",
        "司马懿",
        "葛洪",
        "王衍"
      ]
    },
    "options": [
      {
        "id": "a",
        "label": "A",
        "text": "先想清自己真正怕失去什么，再看哪个选择碰到了它。",
        "delta": {
          "xu_shi": -2,
          "kuang_zhi": 1
        }
      },
      {
        "id": "b",
        "label": "B",
        "text": "出去走一圈，等心里那个更想要的答案浮出来。",
        "delta": {
          "xu_shi": -1,
          "kuang_zhi": -1
        }
      },
      {
        "id": "c",
        "label": "C",
        "text": "把已知条件写下来，只讨论能够证实的部分。",
        "delta": {
          "xu_shi": 1,
          "kuang_zhi": 1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "选眼下损失较小的那个，之后有新情况再修正。",
        "delta": {
          "xu_shi": 2,
          "kuang_zhi": -1
        }
      }
    ]
  },
  {
    "id": "q04",
    "type": "scenario",
    "text": "已经很晚了，一场争论还卡在原地，谁都没有真正被说服。",
    "design": {
      "primaryAxis": "kuang_zhi",
      "secondaryAxis": "qi_zheng",
      "distinguishes": [
        "谢安",
        "桓温",
        "阮籍",
        "苻坚"
      ]
    },
    "options": [
      {
        "id": "a",
        "label": "A",
        "text": "约好明天几点继续，今晚就停在这里。",
        "delta": {
          "kuang_zhi": -2,
          "qi_zheng": 1
        }
      },
      {
        "id": "b",
        "label": "B",
        "text": "发一个无关的表情，把这晚先轻轻放过去。",
        "delta": {
          "kuang_zhi": -1,
          "qi_zheng": -1
        }
      },
      {
        "id": "c",
        "label": "C",
        "text": "把分歧缩成一个问题，只谈完这一件再睡。",
        "delta": {
          "kuang_zhi": 1,
          "qi_zheng": 1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "换一种问法继续追，今晚至少要碰到问题的根。",
        "delta": {
          "kuang_zhi": 2,
          "qi_zheng": -1
        }
      }
    ]
  },
  {
    "id": "q05",
    "type": "scenario",
    "text": "一条规定明显不合理，大家都在抱怨，也都默认继续忍着。",
    "design": {
      "primaryAxis": "qi_zheng",
      "secondaryAxis": "rou_gang",
      "distinguishes": [
        "元宏",
        "宇文泰",
        "何晏",
        "侯景"
      ]
    },
    "options": [
      {
        "id": "a",
        "label": "A",
        "text": "找最受影响的人一起做个小实验，让问题自己露出来。",
        "delta": {
          "qi_zheng": -2,
          "rou_gang": 1
        }
      },
      {
        "id": "b",
        "label": "B",
        "text": "用一句玩笑把荒谬说破，看看现场有谁愿意接话。",
        "delta": {
          "qi_zheng": -1,
          "rou_gang": -1
        }
      },
      {
        "id": "c",
        "label": "C",
        "text": "整理事实，按正式渠道提交一个明确的修改建议。",
        "delta": {
          "qi_zheng": 1,
          "rou_gang": 1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "先和执行的人谈，给他一个能够往上说明的版本。",
        "delta": {
          "qi_zheng": 2,
          "rou_gang": -1
        }
      }
    ]
  },
  {
    "id": "q06",
    "type": "scenario",
    "text": "一个朋友已经连续三次迟到，每次都有听起来说得过去的原因。",
    "design": {
      "primaryAxis": "rou_gang",
      "secondaryAxis": "tui_jin",
      "distinguishes": [
        "谢安",
        "嵇康",
        "王导",
        "高洋"
      ]
    },
    "options": [
      {
        "id": "a",
        "label": "A",
        "text": "先问他最近是不是出了什么事，然后再谈时间。",
        "delta": {
          "rou_gang": -2,
          "tui_jin": 1
        }
      },
      {
        "id": "b",
        "label": "B",
        "text": "这次不说什么，以后少约需要准点的事情。",
        "delta": {
          "rou_gang": -1,
          "tui_jin": -1
        }
      },
      {
        "id": "c",
        "label": "C",
        "text": "当面说我不想再等，请他下次按约定来。",
        "delta": {
          "rou_gang": 1,
          "tui_jin": 1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "下次到了时间我就先走，不再另外提醒。",
        "delta": {
          "rou_gang": 2,
          "tui_jin": -1
        }
      }
    ]
  },
  {
    "id": "q07",
    "type": "scenario",
    "text": "一个机会突然落到你面前。它有吸引力，但条件还没有完全说清。",
    "design": {
      "primaryAxis": "tui_jin",
      "secondaryAxis": "xu_shi",
      "distinguishes": [
        "司马懿",
        "司马昭",
        "陈庆之",
        "高欢"
      ]
    },
    "options": [
      {
        "id": "a",
        "label": "A",
        "text": "先答应试一段时间，很多事只有进去以后才知道。",
        "delta": {
          "tui_jin": 1,
          "xu_shi": -1
        }
      },
      {
        "id": "b",
        "label": "B",
        "text": "把时间、责任和退出条件问清，再决定要不要接。",
        "delta": {
          "tui_jin": -2,
          "xu_shi": 1
        }
      },
      {
        "id": "c",
        "label": "C",
        "text": "先说愿意，具体条件在真正开始前谈妥。",
        "delta": {
          "tui_jin": 2,
          "xu_shi": 1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "找一个不伤人的理由拒绝，模糊本身已经是答案。",
        "delta": {
          "tui_jin": -1,
          "xu_shi": -1
        }
      }
    ]
  },
  {
    "id": "q08",
    "type": "scenario",
    "text": "合住的公共区域越来越乱，几个人对“整洁”的理解完全不同。",
    "design": {
      "primaryAxis": "po_li",
      "secondaryAxis": "kuang_zhi",
      "distinguishes": [
        "王猛",
        "王导",
        "宇文泰",
        "刘裕"
      ]
    },
    "options": [
      {
        "id": "a",
        "label": "A",
        "text": "只定一条规则：用完的东西当天归位。",
        "delta": {
          "po_li": 1,
          "kuang_zhi": -1
        }
      },
      {
        "id": "b",
        "label": "B",
        "text": "先把公共区域彻底清空，再决定什么值得放回来。",
        "delta": {
          "po_li": -2,
          "kuang_zhi": 1
        }
      },
      {
        "id": "c",
        "label": "C",
        "text": "划清每个人的区域，再排一个轮值顺序。",
        "delta": {
          "po_li": 2,
          "kuang_zhi": 1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "扔掉坏的，剩下的留点混乱也没关系。",
        "delta": {
          "po_li": -1,
          "kuang_zhi": -1
        }
      }
    ]
  },
  {
    "id": "q09",
    "type": "scenario",
    "text": "一件关于你的事被传错了。它不至于毁掉什么，但听着很不舒服。",
    "design": {
      "primaryAxis": "xu_shi",
      "secondaryAxis": "qi_zheng",
      "distinguishes": [
        "司马懿",
        "王衍",
        "阮籍",
        "王羲之"
      ]
    },
    "options": [
      {
        "id": "a",
        "label": "A",
        "text": "找最初的当事人私下讲清，不公开回应。",
        "delta": {
          "xu_shi": 1,
          "qi_zheng": -1
        }
      },
      {
        "id": "b",
        "label": "B",
        "text": "写一段不点名的话，只把自己的感受说明白。",
        "delta": {
          "xu_shi": -2,
          "qi_zheng": 1
        }
      },
      {
        "id": "c",
        "label": "C",
        "text": "按时间列出事实，需要的时候一次性公开。",
        "delta": {
          "xu_shi": 2,
          "qi_zheng": 1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "把它当笑话讲几次，让这个说法慢慢失去分量。",
        "delta": {
          "xu_shi": -1,
          "qi_zheng": -1
        }
      }
    ]
  },
  {
    "id": "q10",
    "type": "scenario",
    "text": "一本书已经读到八成，你忽然发现自己根本不想再读。",
