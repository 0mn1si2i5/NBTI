        "delta": {
          "tui_jin": -1,
          "kuang_zhi": -1
        }
      },
      {
        "id": "d",
        "label": "D",
        "text": "不进入这场谈话；值得合作的人迟早会看见。",
        "delta": {
          "tui_jin": -2,
          "kuang_zhi": -1
        }
      }
    ]
  },
  {
