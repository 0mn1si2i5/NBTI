      }
    ]
  },
  {
    "id": "u66f9-u690d",
    "person": "曹植",
    "title": "失焦天才",
    "quote": {
      "text": "悼良会之永绝兮，哀一逝而异乡。",
      "sourceTitle": "《洛神赋》",
      "sourceUrl": "https://zh.wikisource.org/wiki/洛神賦",
      "locator": "《洛神赋》"
    },
    "why": "你像曹植：人生总有一个窗口开错了方向。你不一定输在能力，而是输在系统不需要你这么亮。你会把错位写成光，把失去反复调色，直到它像才华，不像事故。",
    "vector": [
      -0.75,
      -0.75,
      -1.5,
      1.5,
      -0.75,
      -0.75
    ],
    "avatar": "assets/characters/02-cao-zhi.webp",
    "facts": [
      {
        "text": "“七步成诗”的故事把他的才华和危险处境压缩成一个极短镜头。",
        "sourceTitle": "《世说新语·文学》",
        "sourceUrl": "https://zh.wikisource.org/wiki/世說新語",
        "locator": "《世说新语·文学》",
        "sourceKind": "primary"
      },
      {
        "text": "《洛神赋》把失去写成神遇，后世记住的是那种不合时宜的亮。",
        "sourceTitle": "《文选》卷十九",
        "sourceUrl": "https://zh.wikisource.org/wiki/昭明文選",
        "locator": "《文选》卷十九",
        "sourceKind": "primary"
      }
    ]
  },
  {
    "id": "u53f8-u9a6c-u61ff",
    "person": "司马懿",
    "title": "延迟清算",
    "quote": {
      "text": "帝内忌而外宽，猜忌多权变。",
      "sourceTitle": "《晋书·宣帝纪》",
      "sourceUrl": "https://zh.wikisource.org/wiki/晉書/卷001",
      "locator": "《晋书》卷一《宣帝纪》"
    },
    "why": "你像司马懿：不急着赢，急的人会替你暴露漏洞。你习惯把情绪冷藏，把局势备份，把一句话听出三层权限。别人以为你没反应，其实你只是还没点结算。",
    "vector": [
      1.5,
      0.75,
      1.5,
      1.5,
      -0.75,
      0
    ],
    "avatar": "assets/characters/03-sima-yi.webp",
    "facts": [
      {
        "text": "曹爽征召时，他以病重示人；真正动手时，是高平陵的一次清算。",
        "sourceTitle": "《晋书·宣帝纪》",
        "sourceUrl": "https://zh.wikisource.org/wiki/晉書",
        "locator": "《晋书·宣帝纪》",
        "sourceKind": "primary"
      },
      {
        "text": "诸葛亮送女装激他出战，他没有接招，耐心本身就是武器。",
        "sourceTitle": "《晋书·宣帝纪》",
        "sourceUrl": "https://zh.wikisource.org/wiki/晉書",
        "locator": "《晋书·宣帝纪》",
        "sourceKind": "primary"
      }
    ]
  },
  {
    "id": "u53f8-u9a6c-u662d",
    "person": "司马昭",
    "title": "野心亮屏",
    "quote": {
      "text": "司马昭之心，路人所知也。",
      "sourceTitle": "《汉晋春秋》",
      "sourceUrl": "https://zh.wikisource.org/wiki/漢晉春秋",
      "locator": "《汉晋春秋》"
    },
    "why": "你像司马昭：目标已经亮到锁屏都遮不住。你不是不会伪装，只是到某个阶段，继续装谦虚反而浪费电。你要的是把暧昧改成流程，把下一步变成所有人的默认设置。",
    "vector": [
      1.5,
      0,
      1.5,
      1.5,
      0.75,
      1.5
    ],
    "avatar": "assets/characters/04-sima-zhao.webp",
    "facts": [
      {
        "text": "曹髦说“司马昭之心，路人所知也”，野心直接变成成语级弹窗。",
        "sourceTitle": "《汉晋春秋》",
        "sourceUrl": "https://zh.wikisource.org/wiki/漢晉春秋",
        "locator": "《汉晋春秋》",
        "sourceKind": "primary"
      },
      {
        "text": "灭蜀之后受封晋公、晋王，魏晋易代的进度条基本由他拉满。",
        "sourceTitle": "《晋书·文帝纪》",
        "sourceUrl": "https://zh.wikisource.org/wiki/晉書",
        "locator": "《晋书·文帝纪》",
        "sourceKind": "primary"
      }
    ]
  },
  {
    "id": "u4f55-u664f",
    "person": "何晏",
    "title": "概念成瘾",
    "quote": {
      "text": "天地万物，皆以无为本。",
      "sourceTitle": "《晋书·王衍传》引何晏语",
      "sourceUrl": "https://zh.wikisource.org/wiki/晉書/卷043",
      "locator": "《晋书》卷四十三《王衍传》"
    },
    "why": "你像何晏：现实还没动，你已经给它换了一套话术。你敏感于风格、姿态和高级感，知道一个概念一旦流行，大家连焦虑都会换包装。你的危险是把空气当成地基。",
    "vector": [
      0.75,
      0.75,
      -1.5,
      0.75,
      -0.75,
      0
    ],
    "avatar": "assets/characters/05-he-yan.webp",
    "facts": [
      {
        "text": "他与王弼等人开玄谈风气，喜欢把现实问题先换成高级概念。",
        "sourceTitle": "《世说新语·文学》",
        "sourceUrl": "https://zh.wikisource.org/wiki/世說新語",
        "locator": "《世说新语·文学》",
        "sourceKind": "primary"
      },
      {
        "text": "史书写他“美姿仪”，又好谈老庄，形象管理和概念管理同时在线。",
        "sourceTitle": "《三国志·魏书·曹爽传》裴注引《魏略》",
        "sourceUrl": "https://zh.wikisource.org/wiki/三國志",
        "locator": "《三国志·魏书·曹爽传》裴注引《魏略》",
        "sourceKind": "primary"
      }
    ]
  },
  {
    "id": "u738b-u5f3c",
    "person": "王弼",
    "title": "底层改写",
    "quote": {
      "text": "得意在忘象，得象在忘言。",
      "sourceTitle": "《周易略例》",
      "sourceUrl": "https://zh.wikisource.org/wiki/周易略例",
      "locator": "《周易略例·明象》"
    },
    "why": "你像王弼：不抢麦，但会改说明书。别人争谁对谁错，你在看概念有没有内存泄漏。你真正的野心不是赢一场辩论，而是让后来的人只能用你的框架理解问题。",
    "vector": [
      0,
      1.5,
      -1.5,
      0,
      1.5,
      -0.75
    ],
    "avatar": "assets/characters/06-wang-bi.webp",
    "facts": [
      {
        "text": "二十余岁去世，却留下《周易注》《老子注》，像短命的底层系统更新。",
        "sourceTitle": "《三国志·魏书·钟会传》裴注引《王弼传》",
        "sourceUrl": "https://zh.wikisource.org/wiki/三國志",
        "locator": "《三国志·魏书·钟会传》裴注引《王弼传》",
        "sourceKind": "primary"
      },
      {
        "text": "“得意忘象”后来几乎成了玄学式理解世界的快捷键。",
        "sourceTitle": "《周易略例·明象》",
        "sourceUrl": "https://zh.wikisource.org/wiki/周易略例",
        "locator": "《周易略例·明象》",
        "sourceKind": "primary"
      }
    ]
  },
  {
