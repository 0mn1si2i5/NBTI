    "avatar": "assets/characters/12-xie-an.webp",
    "facts": [
      {
        "text": "淝水捷报到时仍下棋，过门槛才折屐齿，情绪管理只在后台报错。",
        "sourceTitle": "《晋书·谢安传》",
        "sourceUrl": "https://zh.wikisource.org/wiki/晉書",
        "locator": "《晋书·谢安传》",
        "sourceKind": "primary"
      },
      {
        "text": "长期隐居东山，后来入仕主持大局，“东山再起”由此有了人格模板。",
